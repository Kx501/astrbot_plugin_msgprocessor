{
  "web_enabled": {
    "description": "启用 Web 配置台",
    "type": "bool",
    "default": true,
    "hint": "在数据目录旁启动静态页与规则接口，便于浏览器编辑 rules.json。"
  },
  "web_host": {
    "description": "Web 监听地址",
    "type": "string",
    "default": "127.0.0.1"
  },
  "web_port": {
    "description": "Web 端口",
    "type": "int",
    "default": 5878
  },
  "translate_llm": {
    "description": "选择提供商",
    "_special": "select_provider",
    "type": "string",
    "default": "default",
    "hint": "翻译使用的模型"
  },
  "llm_translate_prompt": {
    "description": "翻译提示词",
    "type": "text",
    "default": "请将以下文本翻译成中文，只输出译文，不要解释",
    "hint": "传入模型的提示词；待译正文由程序自动追加至末尾。"
  }
}
